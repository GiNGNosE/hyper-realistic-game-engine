{
  "event_name": "pull_request",
  "inputs": {
    "artifacts/policy/acceptance-criteria.json": {
      "json": {
        "present": true
      }
    },
    "artifacts/policy/clarification-log.json": {
      "json": {
        "ambiguities": [],
        "schema_version": "1.0.0"
      }
    },
    "artifacts/policy/governance-conflicts.json": {
      "json": {
        "active_conflicts": 0
      }
    },
    "artifacts/policy/implementation-options.json": {
      "json": {
